      "title": "AppConfiguracao",
      "description": "App settings",
      "type": "object",
      "properties": {
        "chave": { "type": "string" },
        "valor": { "type": "object" }
      }
    },
    "KanbanHistorico": {
      "title": "KanbanHistorico",
      "description": "Kanban status history",
      "type": "object",
      "properties": {
        "iniciativa_id": { "type": "string" },
        "status_de": { "type": "string" },
        "status_para": { "type": "string" },
        "movido_por": { "type": "string" },
        "created_at": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/profiles/{profileId}": { "schema": "Profile", "description": "Profiles collection" },
    "/picklists/{picklistId}": { "schema": "Picklist", "description": "Picklists collection" },
    "/picklist_valores/{picklistValorId}": {
      "schema": "PicklistValor",
      "description": "Picklist values collection"
    },
    "/projetos/{projetoId}": { "schema": "Projeto", "description": "Projects" },
    "/iniciativas/{iniciativaId}": { "schema": "Iniciativa", "description": "Initiatives" },
    "/tarefas/{tarefaId}": { "schema": "Tarefa", "description": "Tasks" },
    "/microprocessos/{microprocessoId}": {
      "schema": "Microprocesso",
      "description": "Microprocesses"
    },
    "/anexos/{anexoId}": { "schema": "Anexo", "description": "Attachments" },
    "/mc3_registros/{mc3RegistroId}": { "schema": "Mc3Registro", "description": "MC3 records" },
    "/reconhecimentos/{reconhecimentoId}": {
      "schema": "Reconhecimento",
      "description": "Reconhecimentos"
    },
    "/user_roles/{userRoleId}": { "schema": "UserRole", "description": "User roles" },
    "/user_session_log/{userSessionLogId}": {
      "schema": "UserSessionLog",
      "description": "User session logs"
    },
    "/formulas/{formulaId}": { "schema": "Formula", "description": "Formulas" },
    "/app_configuracoes/{appConfiguracaoId}": {
      "schema": "AppConfiguracao",
      "description": "App configuration"
    },
    "/kanban_historico/{kanbanHistoricoId}": {
      "schema": "KanbanHistorico",
      "description": "Kanban status history"
    }
  }
}
