        "iniciativa_id": { "type": "string" },
        "created_at": { "type": "string" }
      }
    },
    "Mc3Registro": {
      "title": "Mc3Registro",
      "description": "MC3 records",
      "type": "object",
      "properties": {
        "created_at": { "type": "string" },
        "deleted_at": { "type": "string" }
      }
    },
    "Reconhecimento": {
      "title": "Reconhecimento",
      "description": "Reconhecimentos",
      "type": "object",
      "properties": {
        "created_at": { "type": "string" }
      }
    },
    "UserRole": {
      "title": "UserRole",
      "description": "User roles",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "role": { "type": "string" }
      }
    },
    "UserSessionLog": {
      "title": "UserSessionLog",
      "description": "Session logs",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "email": { "type": "string" },
        "evento": { "type": "string" },
