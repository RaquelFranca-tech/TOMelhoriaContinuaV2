{
  "entities": {
    "Profile": {
      "title": "Profile",
      "description": "User profiles",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "email": { "type": "string" },
        "cargo": { "type": "string" },
        "departamento": { "type": "string" }
      }
    },
    "Picklist": {
      "title": "Picklist",
      "description": "Picklist categories",
      "type": "object",
      "properties": {
        "categoria": { "type": "string" },
        "descricao": { "type": "string" }
      }
    },
    "PicklistValor": {
      "title": "PicklistValor",
      "description": "Values for picklists",
      "type": "object",
      "properties": {
        "picklist_id": { "type": "string" },
        "valor": { "type": "string" },
        "ordem": { "type": "number" },
        "ativo": { "type": "boolean" }
      }
    },
    "Projeto": {
      "title": "Projeto",
      "description": "Projects macros",
