        "deleted_at": { "type": "string" },
        "data_implantacao": { "type": "string" }
      }
    },
    "Tarefa": {
      "title": "Tarefa",
      "description": "Tasks within initiatives",
      "type": "object",
      "properties": {
        "titulo": { "type": "string" },
        "status": { "type": "string" },
        "iniciativa_id": { "type": "string" },
        "responsavel_id": { "type": "string" },
        "data_fim_prevista": { "type": "string" },
        "created_by": { "type": "string" },
        "deleted_at": { "type": "string" }
      }
    },
    "Microprocesso": {
      "title": "Microprocesso",
      "description": "Microprocesses within initiatives",
      "type": "object",
      "properties": {
        "titulo": { "type": "string" },
        "status": { "type": "string" },
        "percentual_avanco": { "type": "number" },
        "iniciativa_id": { "type": "string" },
        "deleted_at": { "type": "string" }
      }
