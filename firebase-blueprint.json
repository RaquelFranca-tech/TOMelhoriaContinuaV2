      "properties": {
        "nome": { "type": "string" },
        "created_by": { "type": "string" },
        "deleted_at": { "type": "string" }
      }
    },
    "Iniciativa": {
      "title": "Iniciativa",
      "description": "Project initiatives",
      "type": "object",
      "properties": {
        "codigo": { "type": "string" },
        "titulo": { "type": "string" },
        "status": { "type": "string" },
        "prioridade": { "type": "string" },
        "percentual_avanco": { "type": "number" },
        "projeto_id": { "type": "string" },
        "data_fim_prevista": { "type": "string" },
        "hc_atual": { "type": "number" },
        "hc_alcancado": { "type": "number" },
        "hc_liberado": { "type": "number" },
        "esforco": { "type": "number" },
        "impacto_negocio": { "type": "number" },
        "lider_id": { "type": "string" },
        "analista_id": { "type": "string" },
        "potencial_automacao": { "type": "string" },
